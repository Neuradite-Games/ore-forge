# Copy to .env and fill in after publishing move/ore_forge (see PROJECT.md).
PUBLIC_SUI_NETWORK=testnet
# Latest package id — used for moveCall targets.
PUBLIC_PACKAGE_ID=0x0
# First-published package id — used for type/event queries. Leave empty to
# reuse PUBLIC_PACKAGE_ID (correct until the first package upgrade).
PUBLIC_ORIGINAL_PACKAGE_ID=
# The shared World object created by the package's init.
PUBLIC_WORLD_ID=0x0
